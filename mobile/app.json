{
  "expo": {
    "name": "NexTalk",
    "slug": "nextalk",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nextalk.app"
    },
    "android": {
      "package": "com.nextalk.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "nextalk",
    "extra": {
      "eas": {
        "projectId": "cd565688-258e-42db-bd00-d2b48bfe3841"
      }
    }
  }
}
